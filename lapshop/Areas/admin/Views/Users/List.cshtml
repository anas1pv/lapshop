@model List<lapshop.Areas.admin.Controllers.UserListViewModel>
@{
    ViewData["Title"] = "Users Management";
}

<div class="col-lg-12 grid-margin stretch-card">
    <div class="card bg-glass">
        <div class="card-body">
            <h4 class="card-title">Registered Users & Roles</h4>
            <p class="card-description">Manage user security access levels directly</p>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>First Name</th>
                            <th>Last Name</th>
                            <th>Email Address</th>
                            <th>Current Role</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>@user.FirstName</td>
                                <td>@user.LastName</td>
                                <td>@user.Email</td>
                                <td>
                                    @foreach (var role in user.Roles)
                                    {
                                        <span class="badge @(role == "Admin" ? "badge-danger" : "badge-info")">@role</span>
                                    }
                                </td>
                                <td>
                                    <form asp-action="ChangeRole" method="post" style="display:inline;">
                                        <input type="hidden" name="userId" value="@user.UserId" />
                                        @if (user.Roles.Contains("Admin"))
                                        {
                                            <input type="hidden" name="newRole" value="Customer" />
                                            <button type="submit" class="btn btn-sm btn-outline-warning">Demote to Customer</button>
                                        }
                                        else
                                        {
                                            <input type="hidden" name="newRole" value="Admin" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Promote to Admin</button>
                                        }
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>