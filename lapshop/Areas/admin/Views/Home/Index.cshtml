@model lapshop.Areas.admin.Controllers.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="row">
    <div class="col-md-4 grid-margin stretch-card">
        <div class="card card-dark-blue">
            <div class="card-body">
                <p class="mb-4">Weekly Sales (Last 7 Days)</p>
                <p class="fs-30 mb-2">$@Model.WeeklySales.ToString("N2")</p>
                <p>Real-time revenue from database</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-4 grid-margin stretch-card">
        <div class="card card-tailwind">
            <div class="card-body">
                <p class="mb-4">Weekly Orders</p>
                <p class="fs-30 mb-2">@Model.WeeklyOrders</p>
                <p>Total sales invoices created</p>
            </div>
        </div>
    </div>

    <div class="col-md-4 grid-margin stretch-card">
        <div class="card card-light-blue">
            <div class="card-body">
                <p class="mb-4">Total Registered Users</p>
                <p class="fs-30 mb-2">@Model.TotalUsers</p>
                <p>Customers and Administrators</p>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <p class="card-title">Monthly Sales Flowchart</p>
                <canvas id="monthlySalesChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-6 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <p class="card-title">Sales by Category</p>
                <canvas id="categoryPieChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-12 grid-margin stretch-card">
        <div class="card bg-glass">
            <div class="card-body">
                <p class="card-title mb-0">Recent Orders (Top 5)</p>
                <div class="table-responsive">
                    <table class="table table-striped table-borderless">
                        <thead>
                            <tr>
                                <th>Invoice ID</th>
                                <th>Customer Name</th>
                                <th>Date</th>
                                <th>Total Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.RecentOrders)
                            {
                                <tr>
                                    <td>#@order.InvoiceId</td>
                                    <td>@order.CustomerName</td>
                                    <td>@order.InvoiceDate.ToString("yyyy-MM-dd")</td>
                                    <td class="font-weight-bold text-success">$@order.Total.ToString("N2")</td>
                                    <td><label class="badge badge-success">@order.Status</label></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/Admin/vendors/chart.js/Chart.min.js"></script>
    <script>
        // استدعاء الـ API لجلب بيانات الـ Charts الحقيقية وتوليدها ديناميكياً
        $.get('/admin/Home/GetSalesStats', function (data) {
            // 1. رسم الـ Line Chart للمبيعات الشهرية
            var monthlyLabels = data.monthly.map(x => x.month);
            var monthlyData = data.monthly.map(x => x.revenue);
            
            new Chart(document.getElementById("monthlySalesChart"), {
                type: 'line',
                data: {
                    labels: monthlyLabels,
                    datasets: [{
                        label: 'Revenue ($)',
                        data: monthlyData,
                        borderColor: '#4B49AC',
                        fill: false
                    }]
                }
            });

            // 2. رسم الـ Pie Chart للمبيعات حسب الـ Category
            var catLabels = data.categories.map(x => x.categoryName);
            var catData = data.categories.map(x => x.revenue);

            new Chart(document.getElementById("categoryPieChart"), {
                type: 'pie',
                data: {
                    labels: catLabels,
                    datasets: [{
                        data: catData,
                        backgroundColor: ['#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0', '#9966FF']
                    }]
                }
            });
        });
    </script>
}