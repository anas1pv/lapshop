@model lapshop.Domains.TbCategory

<div class="content-wrapper">
    <div class="page-header">
        <h3 class="page-title"> Form elements </h3>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="#">Forms</a></li>
                <li class="breadcrumb-item active" aria-current="page">Form elements</li>
            </ol>
        </nav>
    </div>
    <div class="row">
        <div class="col-md-8 grid-margin stretch-card">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title">Category Form</h4>
                    <p class="card-description"> Basic form layout </p>
                    
                    <form class="forms-sample" method="post" enctype="multipart/form-data"
                          asp-controller="Categories" asp-action="Save" role="form">
                        <input asp-for="CurrentState" type="hidden" />
                        <input asp-for="CategoryId" type="hidden" />
                        <input asp-for="CreatedBy" type="hidden" />
                        <input asp-for="CreatedDate" type="hidden" />
                        
                        <input asp-for="ImageName" type="hidden" />

                        <div class="form-group">
                            <label>@ResAdmin.lblCategoryName</label>
                            <input asp-for="CategoryName" type="text" class="form-control" placeholder="Category Name">
                                <span asp-validation-for="CategoryName" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label>@ResAdmin.lblShowHomePage</label>
                                <input asp-for="ShowInHomePage" type="checkbox" />
                            </div>

                            <div class="form-group">
                                <label>@ResAdmin.lblImage</label>
                                <input type="file" name="Files"
                                       class="form-control"
                                       onchange="Upload.UploadDefaultImg(event)"
                                       accept=".jpg, .jpeg, .png, .gif">
                            </div>

                            <button type="submit" class="btn btn-gradient-primary me-2">@ResGeneral.lblSave</button>
                            <a asp-action="List" class="btn btn-light">@ResGeneral.lblCancel</a>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-4 grid-margin stretch-card">
                <div class="card">
                    <div class="card-body text-center">
                        <h6>Image Preview</h6>
                        <span id="tbImgName" class="text-muted d-block mb-2"></span>
                        <div id="tbImgSrc">
                            <img src="/Uploads/Categories/@Model.ImageName"
                                 style="width:200px; height:300px; border-radius: 5px; border: 1px solid #d9d9d9;"
                                 onerror="this.src='/assets/Backend/images/no-image.png'" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @section Scripts
    {
        <script>
            var Upload = {
                UploadDefaultImg: function(e) {
                    const file = e.target.files[0];
                    if (!file) return;

                    const reader = new FileReader();
                    reader.onloadend = () => {
                        $("#tbImgName").html(file.name);
                        $("#tbImgSrc").html(`<img class="thumbnail" src="${reader.result}"  style="width: 200px; height: 300px; border-radius: 5px; border: 1px solid #d9d9d9; padding: 1px;" />`);
                    };
                    reader.readAsDataURL(file);
                }
            }
        </script>
    }