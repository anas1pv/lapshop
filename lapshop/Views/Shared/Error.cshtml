@{
    ViewBag.Title = "Page Not Found";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section-b-space" style="padding: 100px 0;">
    <div class="container">
        <div style="text-align: center; max-width: 500px; margin: 0 auto;">
            <div style="font-size: 120px; font-weight: 800; font-family: 'Outfit', sans-serif; background: linear-gradient(135deg, #7C3AED, #A855F7, #6366F1); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; line-height: 1; margin-bottom: 20px;">
                404
            </div>
            <h2 style="color: #F1F5F9; font-size: 28px; font-weight: 700; margin-bottom: 15px;">Page Not Found</h2>
            <p style="color: #94A3B8; font-size: 16px; margin-bottom: 30px; line-height: 1.6;">
                The page you're looking for doesn't exist or has been moved. Let's get you back on track.
            </p>
            <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
                <a href="/Home/Index" class="btn btn-solid">Go Home</a>
                <a href="/Items/ItemList" class="btn btn-outline" style="border: 2px solid #7C3AED; color: #A855F7; padding: 10px 24px; border-radius: 8px; font-weight: 600;">Browse Products</a>
            </div>
        </div>
    </div>
</section>
