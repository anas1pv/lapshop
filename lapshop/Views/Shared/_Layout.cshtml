@inject SignInManager<ApplicationUser> sinInManager
@inject lapshop.Bl.ISettings settingsService
@{
    var websiteSettings = settingsService.GetAll();
}
<!DOCTYPE html>

<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="LapShop — Your premium destination for laptops. Browse our wide selection of gaming, business, and ultrabook laptops from top brands.">
    <meta name="theme-color" content="#0a0a1a">
    <title>@(ViewBag.Title ?? "LapShop") | Premium Laptop Store</title>
    <link rel="icon" href="~/Fontend/images/favicon/1.png" type="image/x-icon">
    <link rel="shortcut icon" href="~/Fontend/images/favicon/1.png" type="image/x-icon">

    <!--Google font-->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Icons -->
    <link rel="stylesheet" type="text/css" href="~/Fontend/css/fontawesome.css">

    <!--Slick slider css-->
    <link rel="stylesheet" type="text/css" href="~/Fontend/css/slick.css">
    <link rel="stylesheet" type="text/css" href="~/Fontend/css/slick-theme.css">

    <!-- Animate icon -->
    <link rel="stylesheet" type="text/css" href="~/Fontend/css/animate.css">

    <!-- Themify icon -->
    <link rel="stylesheet" type="text/css" href="~/Fontend/css/themify-icons.css">

    <!-- Bootstrap css -->
    <link rel="stylesheet" type="text/css" href="~/Fontend/css/bootstrap.css">

    <!-- Theme css -->
    <link rel="stylesheet" type="text/css" href="~/Fontend/css/color19.css" media="screen" id="color">

    <!-- Custom Tech CSS -->
    <link rel="stylesheet" type="text/css" href="~/Fontend/css/custom-tech.css">

    @RenderSection("Styles", required: false);
</head>

<body>
    <!-- header start -->
    <header class="header-tools marketplace">
        <div class="mobile-fix-option"></div>
        <div class="top-header">
            <div class="container-fluid custom-container">
                <div class="row">
                    <div class="col-lg-6">
                        <div class="header-contact">
                            <ul>
                                <li>Welcome to @websiteSettings.WebsiteName</li>
                                <li><i class="fa fa-phone" aria-hidden="true"></i>Call Us: @websiteSettings.ContactNumber</li>
                            </ul>
                        </div>
                    </div>
                    <div class="col-lg-6 text-right">
                        <ul class="header-dropdown" style="display: flex; justify-content: flex-end; align-items: center; gap: 20px; list-style: none; margin: 0; padding: 0; float: right;">
                            <!-- Search Icon Trigger -->
                            <li style="display: inline-block;">
                                <a href="javascript:void(0)" onclick="openSearch()" style="color: #94A3B8; font-size: 14px; font-weight: 500; text-decoration: none; transition: color 0.3s ease;">
                                    <i class="fa fa-search" aria-hidden="true" style="margin-right: 5px; color: #7C3AED;"></i> Search
                                </a>
                            </li>
                            <!-- Cart Badge Icon -->
                            <li style="display: inline-block; position: relative;">
                                <a href="/Order/Cart" style="color: #94A3B8; font-size: 14px; font-weight: 500; text-decoration: none; transition: color 0.3s ease;">
                                    <i class="fa fa-shopping-cart" aria-hidden="true" style="margin-right: 5px; color: #7C3AED;"></i> Cart
                                    @{
                                        int cartCount = 0;
                                        string cartCookies = Context.Request.Cookies["Cart"];
                                        if (!string.IsNullOrEmpty(cartCookies))
                                        {
                                            try
                                            {
                                                var layoutCart = Newtonsoft.Json.JsonConvert.DeserializeObject<ShoppingCart>(cartCookies);
                                                if (layoutCart != null && layoutCart.lstItems != null)
                                                {
                                                    cartCount = layoutCart.lstItems.Sum(x => (int)x.Qty);
                                                }
                                            }
                                            catch {}
                                        }
                                    }
                                    @if (cartCount > 0)
                                    {
                                        <span id="cartCountBadge" class="badge bg-primary" style="position: absolute; top: -8px; right: -12px; background: #7C3AED !important; color: #fff; font-size: 9px; padding: 3px 5px; border-radius: 50%; font-weight: 700; line-height: 1; box-shadow: 0 0 8px rgba(124, 58, 237, 0.6);">@cartCount</span>
                                    }
                                    else
                                    {
                                        <span id="cartCountBadge" class="badge bg-primary" style="display: none; position: absolute; top: -8px; right: -12px; background: #7C3AED !important; color: #fff; font-size: 9px; padding: 3px 5px; border-radius: 50%; font-weight: 700; line-height: 1; box-shadow: 0 0 8px rgba(124, 58, 237, 0.6);">0</span>
                                    }
                                </a>
                            </li>
                            <!-- My Account -->
                            <li class="onhover-dropdown mobile-account" style="display: inline-block; margin: 0; padding: 0;">
                                <i class="fa fa-user" aria-hidden="true" style="color: #7C3AED;"></i>
                                My Account
                                <ul class="onhover-show-div">
                                    @if (sinInManager.IsSignedIn(User))
                                    {
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <li>
                                                <a href="/admin/Home" style="color: #A855F7 !important; font-weight: bold;">Admin Dashboard</a>
                                            </li>
                                        }
                                        <li>
                                            <a asp-controller="Order" asp-action="MyOrders" data-lng="es">My Orders</a>
                                        </li>
                                        <li>
                                            <a asp-controller="Users" asp-action="LoginOut" data-lng="es">Logout</a>
                                        </li>
                                        <li>
                                            <a asp-controller="Users" asp-action="AccountDetails" data-lng="es">Account details</a>
                                        </li>
                                    }
                                    else
                                    {
                                        <li><a asp-controller="Users" asp-action="Login" data-lng="en">Login</a></li>
                                    }
                                </ul>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <div class="container-fluid custom-container">
            <div class="row">
                <div class="col-sm-12">
                    <div class="main-menu">
                        <div class="menu-left">
                            <div class="navbar">
                                <a href="javascript:void(0)" onclick="openNav()">
                                    <div class="bar-style">
                                        <i class="fa fa-bars sidebar-bar" aria-hidden="true"></i>
                                    </div>
                                </a>
                                <div id="mySidenav" class="sidenav">
                                    <a href="javascript:void(0)" class="sidebar-overlay" onclick="closeNav()"></a>
                                    <nav>
                                        <div onclick="closeNav()">
                                            <div class="sidebar-back text-left">
                                                <i class="fa fa-angle-left pr-2" aria-hidden="true"></i> Back
                                            </div>
                                        </div>
                                        <ul id="sub-menu" class="sm pixelstrap sm-vertical">
                                            <li>
                                                <a href="/Home/Index">Home</a>
                                            </li>
                                            <li>
                                                <a href="/Items/ItemList">Products</a>
                                            </li>
                                            <li>
                                                <a href="/Pages/Index/3">About Us</a>
                                            </li>
                                            <li><a href="/Pages/Index/4">Terms Of Use</a></li>
                                            <li>
                                                <a href="/Pages/Index/5">Contact Us</a>
                                            </li>
                                        </ul>
                                    </nav>
                                </div>
                            </div>
                            <div class="brand-logo" style="padding: 10px 0;">
                                <a href="/Home/Index" style="text-decoration: none;">
                                    <span style="font-family: 'Outfit', sans-serif; font-weight: 800; font-size: 28px; letter-spacing: 2px; color: #7C3AED;">LAP<span style="color: #ffffff;">SHOP</span></span>
                                </a>
                            </div>
                        </div>
                        <div class="menu-right pull-right">
                            <div>
                                <nav id="main-nav">
                                    <div class="toggle-nav"><i class="fa fa-bars sidebar-bar"></i></div>
                                    <ul id="main-menu" class="sm pixelstrap sm-horizontal">
                                        <li>
                                            <div class="mobile-back text-right">
                                                Back<i class="fa fa-angle-right pl-2" aria-hidden="true"></i>
                                            </div>
                                        </li>
                                        <li>
                                            <a href="/Home/Index">Home</a>
                                        </li>
                                        <li>
                                            <a href="/Items/ItemList">Products</a>
                                        </li>
                                        <li id="hover-cls">
                                            <a asp-controller="Pages" asp-action="Index" asp-route-id="3">
                                                About Us
                                            </a>
                                        </li>
                                        <li>
                                            <a asp-controller="Pages" asp-action="Index" asp-route-id="4">
                                                Terms
                                                Of Use
                                            </a>
                                        </li>
                                        <li>
                                            <a asp-controller="Pages" asp-action="Index"
                                               asp-route-id="5">Contact Us</a>
                                        </li>
                                    </ul>
                                </nav>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    @RenderBody()

    <!-- footer -->
    <footer class="footer-light">
        <div class="light-layout">
            <div class="container">
            </div>
        </div>
        <section class="section-b-space light-layout">
            <div class="container">
                <div class="row footer-theme partition-f">
                    <div class="col-lg-4 col-md-6">
                        <div class="footer-title footer-mobile-title">
                            <h4>about</h4>
                        </div>
                        <div class="footer-contant">
                            <div class="footer-logo" style="margin-bottom: 15px;">
                                <a href="/Home/Index" style="text-decoration: none;">
                                    <span style="font-family: 'Outfit', sans-serif; font-weight: 800; font-size: 28px; letter-spacing: 2px; color: #7C3AED;">LAP<span style="color: #ffffff;">SHOP</span></span>
                                </a>
                            </div>
                            <p>
                                @websiteSettings.WebsiteDescription
                            </p>
                            <div class="footer-social">
                                <ul>
                                    <li>
                                        <a id="lnkFacebook" href="@websiteSettings.FacebookLink" target="_blank">
                                            <i class="fa fa-facebook" aria-hidden="true"></i>
                                        </a>
                                    </li>
                                    <li><a href="@websiteSettings.TwitterLink" target="_blank"><i class="fa fa-twitter" aria-hidden="true"></i></a></li>
                                    <li><a href="@websiteSettings.InstgramLink" target="_blank"><i class="fa fa-instagram" aria-hidden="true"></i></a></li>
                                    <li><a href="@websiteSettings.YoutubeLink" target="_blank"><i class="fa fa-youtube-play" aria-hidden="true"></i></a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="col offset-xl-1">
                        <div class="sub-title">
                            <div class="footer-title">
                                <h4>my account</h4>
                            </div>
                            <div class="footer-contant">
                                <ul>
                                    <li><a href="/Items/ItemList">All Products</a></li>
                                    <li><a href="/Home/Index">Home Portal</a></li>
                                    <li><a href="/Order/Cart">Shopping Cart</a></li>
                                    <li><a href="/Order/MyOrders">My Orders</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="sub-title">
                            <div class="footer-title">
                                <h4>why we choose</h4>
                            </div>
                            <div class="footer-contant">
                                <ul>
                                    <li><a href="/Pages/Index/3">About Us</a></li>
                                    <li><a href="/Pages/Index/4">Terms Of Use</a></li>
                                    <li><a href="/Pages/Index/5">Contact Us</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="sub-title">
                            <div class="footer-title">
                                <h4>store information</h4>
                            </div>
                            <div class="footer-contant">
                                <ul class="contact-list">
                                    <li>
                                        <i class="fa fa-map-marker"></i>@websiteSettings.Address
                                    </li>
                                    <li><i class="fa fa-phone"></i>Call Us: @websiteSettings.ContactNumber</li>
                                    <li>
                                        <i class="fa fa-envelope-o"></i>Email Us: <a href="mailto:support@lapshop.com">support@lapshop.com</a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <div class="sub-footer">
            <div class="container">
                <div class="row">
                    <div class="col-xl-6 col-md-6 col-sm-12">
                        <div class="footer-end">
                            <p>
                                <i class="fa fa-copyright" aria-hidden="true"></i> 2025 LapShop. All rights reserved.
                            </p>
                        </div>
                    </div>
                    <div class="col-xl-6 col-md-6 col-sm-12">
                        <div class="payment-card-bottom">
                            <ul>
                                <li>
                                    <a href="#"><img src="~/Fontend/images/icon/visa.png" alt=""></a>
                                </li>
                                <li>
                                    <a href="#"><img src="~/Fontend/images/icon/mastercard.png" alt=""></a>
                                </li>
                                <li>
                                    <a href="#"><img src="~/Fontend/images/icon/paypal.png" alt=""></a>
                                </li>
                                <li>
                                    <a href="#"><img src="~/Fontend/images/icon/american-express.png" alt=""></a>
                                </li>
                                <li>
                                    <a href="#"><img src="~/Fontend/images/icon/discover.png" alt=""></a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </footer>
    <!-- footer end -->
    <!--modal popup removed-->
    <!-- theme setting removed -->
    <!-- search overlay -->
    <div id="search-overlay" class="search-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(10,10,26,0.95); z-index: 9999; backdrop-filter: blur(10px);">
        <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 90%; max-width: 600px;">
            <button onclick="closeSearch()" style="position: absolute; top: -50px; right: 0; background: none; border: none; color: #fff; font-size: 28px; cursor: pointer;"><i class="fa fa-times"></i></button>
            <form action="/Items/ItemList" method="get" style="display: flex; gap: 10px;">
                <input type="text" name="search" placeholder="Search laptops..." style="flex: 1; padding: 18px 24px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 12px; color: #fff; font-size: 18px; outline: none; font-family: 'Inter', sans-serif;" autofocus />
                <button type="submit" style="padding: 18px 32px; background: linear-gradient(135deg, #7C3AED, #6366F1); border: none; border-radius: 12px; color: #fff; font-size: 16px; cursor: pointer; font-family: 'Inter', sans-serif;"><i class="fa fa-search"></i></button>
            </form>
        </div>
    </div>
<!-- tap to top -->
<div class="tap-top top-cls">
    <div>
        <i class="fa fa-angle-double-up"></i>
    </div>
</div>
<!-- tap to top end -->
<!-- latest jquery-->
<script src="~/Fontend/js/jquery-3.3.1.min.js"></script>

<!-- fly cart ui jquery-->
<script src="~/Fontend/js/jquery-ui.min.js"></script>

<!-- exitintent jquery-->
<script src="~/Fontend/js/jquery.exitintent.js"></script>
<script src="~/Fontend/js/exit.js"></script>

<!-- popper js-->
<script src="~/Fontend/js/popper.min.js"></script>

<!-- slick js-->
<script src="~/Fontend/js/slick.js"></script>

<!-- menu js-->
<script src="~/Fontend/js/menu.js"></script>

<!-- lazyload js-->
<script src="~/Fontend/js/lazysizes.min.js"></script>

<!-- Bootstrap js-->
<script src="~/Fontend/js/bootstrap.js"></script>

<!-- Bootstrap Notification js-->
<script src="~/Fontend/js/bootstrap-notify.min.js"></script>

<!-- Fly cart js-->
<script src="~/Fontend/js/fly-cart.js"></script>

<!-- Theme js-->
<script src="~/Fontend/js/script.js"></script>

<script src="~/modules/helper.js"></script>
<script src="~/modules/settings.js"></script>
@RenderSection("Scripts", required: false);

<script>
    function openSearch() {
        document.getElementById('search-overlay').style.display = 'block';
        document.getElementById('search-overlay').querySelector('input').focus();
    }
    function closeSearch() {
        document.getElementById('search-overlay').style.display = 'none';
    }
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeSearch();
    });
    function AddToCartAjax(itemId) {
        Helper.AjaxCallGet("/Order/AddToCartAjax?itemId=" + itemId, {}, "json", function(response) {
            if (response && response.success) {
                var badge = $('#cartCountBadge');
                if (badge.length) {
                    badge.text(response.cartCount);
                    badge.show();
                }
                NotificationHelper.ShowSuccess("Laptop added to cart successfully!");
            } else {
                NotificationHelper.ShowError("Could not add item to cart.");
            }
        }, function() {
            NotificationHelper.ShowError("Connection error while adding to cart.");
        });
    }
</script>
        
</body>

</html>