@model lapshop.Domains.TbPage

<!-- breadcrumb start -->
<div class="breadcrumb-section">
    <div class="container">
        <div class="row">
            <div class="col-sm-6">
                <div class="page-title">
                    <h2>@Model.Title</h2>
                </div>
            </div>
            <div class="col-sm-6">
                <nav aria-label="breadcrumb" class="theme-breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/Home/Index">Home</a></li>
                        <li class="breadcrumb-item active" aria-current="page">@Model.Title</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>
<!-- breadcrumb End -->

<!-- content section -->
<section class="about-page section-b-space">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="page-content-container">
                    @if (!string.IsNullOrEmpty(Model.ImageName))
                    {
                        <div style="margin-bottom: 30px; border-radius: 12px; overflow: hidden; max-height: 400px;">
                            <img src="~/Uploads/Pages/@Model.ImageName" class="img-fluid" alt="@Model.Title" style="width: 100%; object-fit: cover; filter: brightness(0.8);">
                        </div>
                    }
                    
                    <h3 style="font-weight: 700; font-size: 28px; margin-bottom: 25px; padding-bottom: 15px; border-bottom: 2px solid rgba(124,58,237,0.3); display: inline-block;">@Model.Title</h3>
                    
                    <div class="page-description-content" style="line-height: 1.9; font-size: 16px;">
                        @Html.Raw(HtmlSanitizer.Sanitize(Model.Description))
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
