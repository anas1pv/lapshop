@model ResetPasswordViewModel
@{
    ViewBag.Title = "Reset Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="register-page section-b-space" style="padding: 100px 0;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-8 col-sm-10">
                <div class="theme-card-dark" style="background: rgba(15, 15, 42, 0.65); border: 1px solid rgba(124, 58, 237, 0.15); border-radius: 16px; padding: 40px; backdrop-filter: blur(12px); box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);">
                    <div style="text-align: center; margin-bottom: 30px;">
                        <i class="fa fa-unlock-alt" style="font-size: 50px; color: #A855F7; display: block; margin-bottom: 15px;"></i>
                        <h3 style="color: #F1F5F9; font-weight: 800; font-size: 24px; font-family: 'Outfit', sans-serif;">Reset Password</h3>
                        <p style="color: #94A3B8; font-size: 14px; margin-top: 5px;">Enter your new password below.</p>
                    </div>

                    <form class="theme-form" asp-controller="Users" asp-action="ResetPassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 20px; font-size: 14px;"></div>
                        
                        <input type="hidden" asp-for="Code" />
                        <input type="hidden" asp-for="Email" />

                        <div class="form-group" style="margin-bottom: 20px;">
                            <label asp-for="Password" style="color: #94A3B8; font-weight: 500; font-size: 14px; margin-bottom: 8px;">New Password</label>
                            <input type="password" asp-for="Password" class="form-control" placeholder="Enter new password" style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(124, 58, 237, 0.15); border-radius: 8px; color: #F1F5F9; padding: 12px 16px; font-size: 14px;" required />
                            <span asp-validation-for="Password" class="text-danger" style="font-size: 12px; margin-top: 5px; display: block;"></span>
                        </div>

                        <div class="form-group" style="margin-bottom: 25px;">
                            <label asp-for="ConfirmPassword" style="color: #94A3B8; font-weight: 500; font-size: 14px; margin-bottom: 8px;">Confirm Password</label>
                            <input type="password" asp-for="ConfirmPassword" class="form-control" placeholder="Confirm new password" style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(124, 58, 237, 0.15); border-radius: 8px; color: #F1F5F9; padding: 12px 16px; font-size: 14px;" required />
                            <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size: 12px; margin-top: 5px; display: block;"></span>
                        </div>

                        <button type="submit" class="btn btn-solid" style="width: 100%; border-radius: 8px; padding: 14px 20px; font-size: 15px; font-weight: 600; text-transform: uppercase; margin-bottom: 20px;">Reset Password</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
