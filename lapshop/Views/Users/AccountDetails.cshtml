@{
    ViewBag.Title = "Account Details";
}

<div class="breadcrumb-section">
    <div class="container">
        <div class="row">
            <div class="col-sm-6">
                <div class="page-title">
                    <h2>My Account</h2>
                </div>
            </div>
            <div class="col-sm-6">
                <nav aria-label="breadcrumb" class="theme-breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/Home/Index">Home</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Account</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<section class="section-b-space">
    <div class="container">
        <div class="row" style="justify-content: center;">
            <div class="col-lg-8">
                <div style="text-align: center; margin-bottom: 30px;">
                    <div style="width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, #7C3AED, #6366F1); display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; box-shadow: 0 0 30px rgba(124,58,237,0.3);">
                        <i class="fa fa-user" style="font-size: 32px; color: #fff;"></i>
                    </div>
                    <h3 style="color: #F1F5F9; font-size: 26px; font-weight: 700; margin-bottom: 5px;">My Account</h3>
                    <p style="color: #64748B; font-size: 14px;">Manage your account settings</p>
                </div>

                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-top: 30px;">
                    <!-- Order History Card -->
                    <a href="/Order/MyOrders" style="text-decoration: none;">
                        <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 30px; text-align: center; transition: all 0.3s ease; backdrop-filter: blur(20px);"
                             onmouseover="this.style.borderColor='rgba(124,58,237,0.4)'; this.style.transform='translateY(-4px)'; this.style.boxShadow='0 8px 30px rgba(124,58,237,0.15)'"
                             onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'; this.style.transform='translateY(0)'; this.style.boxShadow='none'">
                            <i class="fa fa-shopping-bag" style="font-size: 36px; color: #A855F7; margin-bottom: 15px; display: block;"></i>
                            <h5 style="color: #F1F5F9; font-weight: 600; margin-bottom: 8px;">My Orders</h5>
                            <p style="color: #64748B; font-size: 13px; margin: 0;">View your order history</p>
                        </div>
                    </a>

                    <!-- Cart Card -->
                    <a href="/Order/Cart" style="text-decoration: none;">
                        <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 30px; text-align: center; transition: all 0.3s ease; backdrop-filter: blur(20px);"
                             onmouseover="this.style.borderColor='rgba(124,58,237,0.4)'; this.style.transform='translateY(-4px)'; this.style.boxShadow='0 8px 30px rgba(124,58,237,0.15)'"
                             onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'; this.style.transform='translateY(0)'; this.style.boxShadow='none'">
                            <i class="ti-shopping-cart" style="font-size: 36px; color: #22D3EE; margin-bottom: 15px; display: block;"></i>
                            <h5 style="color: #F1F5F9; font-weight: 600; margin-bottom: 8px;">Shopping Cart</h5>
                            <p style="color: #64748B; font-size: 13px; margin: 0;">View your current cart</p>
                        </div>
                    </a>

                    <!-- Browse Products Card -->
                    <a href="/Items/ItemList" style="text-decoration: none;">
                        <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 30px; text-align: center; transition: all 0.3s ease; backdrop-filter: blur(20px);"
                             onmouseover="this.style.borderColor='rgba(124,58,237,0.4)'; this.style.transform='translateY(-4px)'; this.style.boxShadow='0 8px 30px rgba(124,58,237,0.15)'"
                             onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'; this.style.transform='translateY(0)'; this.style.boxShadow='none'">
                            <i class="fa fa-laptop" style="font-size: 36px; color: #10B981; margin-bottom: 15px; display: block;"></i>
                            <h5 style="color: #F1F5F9; font-weight: 600; margin-bottom: 8px;">Browse Products</h5>
                            <p style="color: #64748B; font-size: 13px; margin: 0;">Explore our catalog</p>
                        </div>
                    </a>

                    <!-- Logout Card -->
                    <a asp-controller="Users" asp-action="LoginOut" style="text-decoration: none;">
                        <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 30px; text-align: center; transition: all 0.3s ease; backdrop-filter: blur(20px);"
                             onmouseover="this.style.borderColor='rgba(239,68,68,0.4)'; this.style.transform='translateY(-4px)'; this.style.boxShadow='0 8px 30px rgba(239,68,68,0.15)'"
                             onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'; this.style.transform='translateY(0)'; this.style.boxShadow='none'">
                            <i class="fa fa-sign-out" style="font-size: 36px; color: #EF4444; margin-bottom: 15px; display: block;"></i>
                            <h5 style="color: #F1F5F9; font-weight: 600; margin-bottom: 8px;">Logout</h5>
                            <p style="color: #64748B; font-size: 13px; margin: 0;">Sign out of your account</p>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
