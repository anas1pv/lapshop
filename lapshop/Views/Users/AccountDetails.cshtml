@model lapshop.Models.AccountDetailsViewModel
@{
    ViewData["Title"] = "Account Details";
}

<div class="container mt-5 mb-5">
    <div class="card mb-4 bg-light shadow-sm">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h4>Welcome, @Model.FirstName @Model.LastName!</h4>
                <p class="text-muted mb-0">Email: @Model.Email | Role: <span class="badge badge-primary">@Model.Role</span></p>
            </div>
            <div>
                @if (Model.IsEmailConfirmed)
                {
                    <span class="badge badge-success p-2">🌐 Verified Email</span>
                }
                else
                {
                    <span class="badge badge-warning p-2">⚠️ Email Unverified</span>
                }
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">🧑‍💻 Edit Profile Metadata</h5>
                </div>
                <div class="card-body">
                    <form asp-action="UpdateProfile" method="post">
                        @Html.AntiForgeryToken()
                        <div class="form-group mb-3">
                            <label asp-for="FirstName">First Name</label>
                            <input type="text" asp-for="FirstName" class="form-control" />
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="LastName">Last Name</label>
                            <input type="text" asp-for="LastName" class="form-control" />
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="Email">Email Address</label>
                            <input type="email" asp-for="Email" class="form-control" />
                        </div>
                        <button type="submit" class="btn btn-success w-100">Update Profile Info</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card shadow-sm">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">🔒 Security & Password Reset</h5>
                </div>
                <div class="card-body">
                    <form asp-action="ChangePassword" method="post">
                        @Html.AntiForgeryToken()
                        <div class="form-group mb-3">
                            <label asp-for="CurrentPassword">Current Password</label>
                            <input type="password" asp-for="CurrentPassword" class="form-control" />
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="NewPassword">New Password</label>
                            <input type="password" asp-for="NewPassword" class="form-control" />
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="ConfirmPassword">Confirm New Password</label>
                            <input type="password" asp-for="ConfirmPassword" class="form-control" />
                        </div>
                        <button type="submit" class="btn btn-danger w-100">Apply New Password</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>