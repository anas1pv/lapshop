@model UserModel

<div class="breadcrumb-section">
    <div class="container">
        <div class="row">
            <div class="col-sm-6">
                <div class="page-title">
                    <h2>Sign In</h2>
                </div>
            </div>
            <div class="col-sm-6">
                <nav aria-label="breadcrumb" class="theme-breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/Home/Index">Home</a></li>
                        <li class="breadcrumb-item active">Login</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<section class="login-page section-b-space">
    <div class="container">
        <div class="row" style="justify-content: center;">
            <div class="col-lg-5">
                <div style="text-align: center; margin-bottom: 30px;">
                    <div style="width: 70px; height: 70px; border-radius: 50%; background: linear-gradient(135deg, #7C3AED, #6366F1); display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; box-shadow: 0 0 25px rgba(124,58,237,0.3);">
                        <i class="fa fa-lock" style="font-size: 28px; color: #fff;"></i>
                    </div>
                    <h3 style="color: #F1F5F9; font-size: 26px; font-weight: 700; margin-bottom: 8px;">Welcome Back</h3>
                    <p style="color: #64748B; font-size: 14px;">Sign in to your LapShop account</p>
                </div>
                <div class="theme-card" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 35px; box-shadow: 0 4px 24px rgba(0,0,0,0.3); backdrop-filter: blur(20px);">
                    <form method="post" asp-controller="Users" asp-action="Login" class="theme-form">
                        <input asp-for="ReturnUrl" type="hidden" />
                        <div class="form-group">
                            <label for="email" style="color: #94A3B8; font-weight: 500; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px;">Email Address</label>
                            <input asp-for="Email" type="text" class="form-control" id="email" placeholder="Enter your email" required="">
                        </div>
                        <div class="form-group">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                                <label for="review" style="color: #94A3B8; font-weight: 500; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px; margin: 0;">Password</label>
                                <a href="/Users/ForgotPassword" style="color: #A855F7; font-size: 12px; font-weight: 500; text-decoration: none;">Forgot Password?</a>
                            </div>
                            <input asp-for="Password" type="password" class="form-control" id="review" placeholder="Enter your password" required="">
                        </div>
                        <button type="submit" class="btn btn-solid" style="width: 100%; padding: 14px; font-size: 15px; border-radius: 10px; margin-top: 10px;">Sign In</button>
                    </form>
                </div>
                <div style="text-align: center; margin-top: 25px;">
                    <p style="color: #64748B; font-size: 14px;">Don't have an account? <a href="/Users/Register" style="color: #A855F7; font-weight: 600;">Create Account</a></p>
                </div>
            </div>
        </div>
    </div>
</section>
