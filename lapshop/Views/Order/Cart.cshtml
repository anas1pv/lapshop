@model ShoppingCart

<!-- breadcrumb start -->
<div class="breadcrumb-section">
    <div class="container">
        <div class="row">
            <div class="col-sm-6">
                <div class="page-title">
                    <h2>Shopping Cart</h2>
                </div>
            </div>
            <div class="col-sm-6">
                <nav aria-label="breadcrumb" class="theme-breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/Home/Index">Home</a></li>
                        <li class="breadcrumb-item active">Cart</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>
<!-- breadcrumb End -->
<!--section start-->
<section class="cart-section section-b-space">
    <div class="container">
        @if (Model.lstItems != null && Model.lstItems.Count > 0)
        {
        <div class="row">
            <div class="col-sm-12">
                <table class="table cart-table table-responsive-xs">
                    <thead>
                        <tr class="table-head">
                            <th scope="col">Image</th>
                            <th scope="col">Product Name</th>
                            <th scope="col">Price</th>
                            <th scope="col">Quantity</th>
                            <th scope="col">Action</th>
                            <th scope="col">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.lstItems)
                        {
                            <tr>
                                <td>
                                    <a asp-controller="Items" asp-action="ItemDetails" asp-route-id="@item.ItemId"><img src="~/Uploads/Items/@item.ImageName" alt="@item.ItemName" style="max-width: 80px; border-radius: 8px; background: rgba(255,255,255,0.03); padding: 4px;"></a>
                                </td>
                                <td>
                                    <a asp-controller="Items" asp-action="ItemDetails" asp-route-id="@item.ItemId">@item.ItemName</a>
                                </td>
                                <td>
                                    <h2 style="color: #F1F5F9; font-size: 16px;">$@item.Price</h2>
                                </td>
                                <td>
                                    <div class="qty-box">
                                        <div class="input-group">
                                            <input type="number" name="quantity"
                                               class="form-control input-number qty"
                                               data-id="@item.ItemId" data-price="@item.Price"
                                                   value="@item.Qty" oninput="ChangeQty(this)" min="1">
                                        </div>
                                    </div>
                                </td>
                                <td><a href="/Order/RemoveFromCart?itemId=@item.ItemId" class="icon" style="color: #EF4444; font-size: 18px;" title="Remove"><i class="ti-close"></i></a></td>
                                <td>
                                    <h2 data-id="@item.ItemId" class="td-color totalPrice" style="color: #A855F7; font-weight: 700; font-size: 16px;">@item.Total</h2>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <table class="table cart-table table-responsive-md">
                    <tfoot>
                        <tr>
                            <td style="color: #94A3B8; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">Total Price :</td>
                            <td>
                                <h2 id="OverAllTotal" style="color: #A855F7; font-weight: 700; font-size: 22px;">$@Model.Total</h2>
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
        <div class="row cart-buttons" style="margin-top: 20px;">
            <div class="col-6"><a href="/Items/ItemList" class="btn btn-solid">Continue Shopping</a></div>
            <div class="col-6 text-right"><a href="/Order/OrderSuccess" class="btn btn-solid">Checkout</a></div>
        </div>
        }
        else
        {
        <div class="empty-state" style="text-align: center; padding: 80px 20px;">
            <i class="ti-shopping-cart" style="font-size: 72px; color: #64748B; display: block; margin-bottom: 20px;"></i>
            <h3 style="color: #F1F5F9; font-size: 24px; margin-bottom: 10px;">Your Cart is Empty</h3>
            <p style="color: #94A3B8; margin-bottom: 25px;">Looks like you haven't added any laptops yet.</p>
            <a href="/Items/ItemList" class="btn btn-solid">Start Shopping</a>
        </div>
        }
    </div>
</section>
<!--section end-->
@section Scripts
{
    <script>
        function ChangeQty(input) {
            let id = input.dataset.id;
            let price = parseFloat(input.dataset.price);
            let qty = parseInt(input.value) || 0;
            if (qty < 1) {
                qty = 1;
                input.value = 1;
            }
            let overAllTotal = 0;

            let totalPrices = document.querySelectorAll(".totalPrice");

            totalPrices.forEach(function(element) {
                if (element.dataset.id === id) {
                    element.innerHTML = (price * qty).toFixed(2);
                }

                let currentPrice = parseFloat(element.innerText) || 0;
                overAllTotal += currentPrice;
            });

            document.getElementById("OverAllTotal").innerHTML = "$" + overAllTotal.toFixed(2);

            // Save quantity update back to cookie
            var formData = new FormData();
            formData.append("itemId", id);
            formData.append("qty", qty);

            fetch("/Order/UpdateQuantity", {
                method: "POST",
                body: formData
            }).then(function(response) {
                if (response.ok) {
                    // Recalculate badge total quantity
                    var totalBadgeCount = 0;
                    document.querySelectorAll(".qty").forEach(function(el) {
                        totalBadgeCount += parseInt(el.value) || 0;
                    });
                    var badge = document.getElementById("cartCountBadge");
                    if (badge) {
                        badge.innerText = totalBadgeCount;
                        if (totalBadgeCount > 0) {
                            badge.style.display = "inline-block";
                        } else {
                            badge.style.display = "none";
                        }
                    }
                }
            }).catch(function(err) {
                console.error("Error updating cart quantity on server: ", err);
            });
        }
    </script>
}
