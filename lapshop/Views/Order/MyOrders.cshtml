@model List<lapshop.Domains.VwSalesInvoice>

<div class="breadcrumb-section">
    <div class="container">
        <div class="row">
            <div class="col-sm-6">
                <div class="page-title">
                    <h2>My Orders</h2>
                </div>
            </div>
            <div class="col-sm-6">
                <nav aria-label="breadcrumb" class="theme-breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/Home/Index">Home</a></li>
                        <li class="breadcrumb-item active" aria-current="page">My Orders</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<section class="cart-section section-b-space">
    <div class="container">
        <div class="row">
            <div class="col-sm-12">
                @if (Model == null || Model.Count == 0)
                {
                    <div class="empty-state">
                        <i class="fa fa-shopping-bag"></i>
                        <h3>No Orders Yet</h3>
                        <p>You haven't placed any orders. Browse our catalog and find the perfect laptop.</p>
                        <a href="/Items/ItemList" class="btn btn-solid">Start Shopping</a>
                    </div>
                }
                else
                {
                    <h3 style="font-weight: 700; margin-bottom: 25px; color: #F1F5F9; font-size: 22px;">Order History</h3>
                    <div class="order-table-container">
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th scope="col">Order ID</th>
                                        <th scope="col">Order Date</th>
                                        <th scope="col">Delivery Date</th>
                                        <th scope="col">Customer</th>
                                        <th scope="col">Status</th>
                                        <th scope="col">Notes</th>
                                        <th scope="col">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model)
                                    {
                                        <tr>
                                            <td>
                                                <span style="font-weight: 600; color: #A855F7;">#@order.InvoiceId</span>
                                            </td>
                                            <td style="color: #94A3B8;">
                                                @order.InvoiceDate.ToString("MMM dd, yyyy")
                                            </td>
                                            <td style="color: #94A3B8;">
                                                @order.DelivryDate.ToString("MMM dd, yyyy")
                                            </td>
                                            <td style="color: #F1F5F9; font-weight: 500;">
                                                @order.FirstName @order.LastName
                                            </td>
                                            <td>
                                                <span class="badge-status badge-delivered">Delivered</span>
                                            </td>
                                            <td style="color: #64748B; font-style: italic;">
                                                @(string.IsNullOrEmpty(order.Notes) ? "—" : order.Notes)
                                            </td>
                                            <td>
                                                <a href="/Order/OrderDetails/@order.InvoiceId" class="btn btn-solid" style="padding: 6px 14px; font-size: 12px; text-transform: uppercase; border-radius: 6px; letter-spacing: 0px;">View Details</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
